<h1><%= title %></h1>

<%- messages() %>
<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>
<div class="login-container">
  <form method="post" action="/account/login" class="login-form">

    <label for="email">Email:</label>
    <input type="email" name="account_email" id="email" required>

    <label for="password">Password:</label>

    <div class="password-info">
      Must contain at least 12 characters, 1 uppercase, 1 number, 1 symbol.
    </div>

    <input 
      type="password" 
      name="account_password" 
      id="password" 
      required
      pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$"
    >

    <button type="submit">Login</button>
  </form>

  <p class="register-link">
    Don't have an account?
    <a href="/account/register">Register here</a>
  </p>
</div>